{
  "name": "pi-quests",
  "version": "0.6.2",
  "description": "A quest-log for your pi. Keep your agent on track, one quest at a time.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "quests",
    "snapshot",
    "rollback",
    "todo"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalindudc/pi-quests.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "files": [
    "src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.md"
  ],
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@mariozechner/pi-coding-agent": "^0.70.2",
    "@mariozechner/pi-tui": "^0.70.2",
    "typebox": "^1.1.33",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "style": "biome check --error-on-warnings ./src ./test",
    "style:fix": "biome check --write --unsafe --no-errors-on-unmatched --error-on-warnings ./src ./test",
    "format": "biome format --write --no-errors-on-unmatched ./src ./test",
    "prepublishOnly": "npx tsc --noEmit && npx vitest run",
    "prepare": "bash scripts/setup.sh",
    "cleanup": "bash scripts/cleanup.sh",
    "dev": "bash scripts/dev.sh",
    "logs": "bash scripts/logs.sh"
  }
}
