#!/usr/bin/env bash
# pre-commit hook: run style checks and tests before allowing a commit

set -euo pipefail

echo "==> pre-commit: running style checks..."
if ! npm run style:fix; then
  echo ""
  echo "Style check failed. Fix the issues above before committing."
  echo "  To skip this hook: git commit --no-verify"
  exit 1
fi

echo ""
echo "==> pre-commit: running type check..."
if ! npm run typecheck; then
  echo ""
  echo "Type check failed. Fix the issues above before committing."
  echo "  To skip this hook: git commit --no-verify"
  exit 1
fi

echo ""
echo "==> pre-commit: running tests..."
if ! npm test; then
  echo ""
  echo "Tests failed. Fix the failures above before committing."
  echo "  To skip this hook: git commit --no-verify"
  exit 1
fi

echo ""
echo "pre-commit: all checks passed"
